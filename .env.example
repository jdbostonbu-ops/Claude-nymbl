# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your values. Never commit real keys.
# ---------------------------------------------------------------------------

# OpenAI — powers the "Write my script" demo (server-side only, never exposed)
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: override the model used for script generation (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Cal.com — your 15-minute booking link (public; safe to expose)
# Example: https://cal.com/your-username/15min
NEXT_PUBLIC_CAL_LINK=https://cal.com/your-username/15min

# Stripe Checkout Sessions (TEST MODE) — server-side only, never exposed
# Create recurring monthly Prices in Stripe, then paste their price_ IDs below.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
STRIPE_PRICE_KICKSTART=price_your_50_monthly_kickstart_id
STRIPE_PRICE_CRUISE=price_your_150_monthly_cruise_id
STRIPE_PRICE_THROTTLE=price_your_500_monthly_throttle_id
